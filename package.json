{
  "name": "dkit",
  "version": "1.0.0",
  "description": "CLI moderna para automatizar tarefas em projetos frontend existentes",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "bin": {
    "dkit": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build ./src/index.ts --outdir ./dist --target bun",
    "typecheck": "tsc --noEmit",
    "lint": "bun run typecheck"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^26.1.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@clack/prompts": "^1.7.0",
    "commander": "^15.0.0"
  },
  "trustedDependencies": [
    "@clack/prompts"
  ]
}
