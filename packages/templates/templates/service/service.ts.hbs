import type { {{pascalName}} } from "../types";

const API_BASE = process.env.NEXT_PUBLIC_API_URL ?? "";

export const {{camelName}}Service = {
  async getAll(): Promise<{{pascalName}}[]> {
    const response = await fetch(`${API_BASE}/{{kebabName}}s`);
    if (!response.ok) throw new Error("Failed to fetch {{kebabName}}s");
    return response.json();
  },

  async getById(id: string): Promise<{{pascalName}}> {
    const response = await fetch(`${API_BASE}/{{kebabName}}s/${id}`);
    if (!response.ok) throw new Error("Failed to fetch {{kebabName}}");
    return response.json();
  },

  async create(data: Partial<{{pascalName}}>): Promise<{{pascalName}}> {
    const response = await fetch(`${API_BASE}/{{kebabName}}s`, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(data),
    });
    if (!response.ok) throw new Error("Failed to create {{kebabName}}");
    return response.json();
  },

  async update(id: string, data: Partial<{{pascalName}}>): Promise<{{pascalName}}> {
    const response = await fetch(`${API_BASE}/{{kebabName}}s/${id}`, {
      method: "PATCH",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(data),
    });
    if (!response.ok) throw new Error("Failed to update {{kebabName}}");
    return response.json();
  },

  async delete(id: string): Promise<void> {
    const response = await fetch(`${API_BASE}/{{kebabName}}s/${id}`, {
      method: "DELETE",
    });
    if (!response.ok) throw new Error("Failed to delete {{kebabName}}");
  },
};
