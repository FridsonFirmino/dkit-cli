    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@dkit/core": "workspace:*",
    "@dkit/shared": "workspace:*",
    "commander": "^13.1.0",
    "@clack/prompts": "^0.10.0",
    "picocolors": "^1.1.1",
    "ora": "^8.2.0"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.7.0"
  }
}
