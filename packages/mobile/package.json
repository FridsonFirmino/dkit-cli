{
  "name": "@dkit/mobile",
  "version": "0.1.0",
  "description": "DKIT Mobile - Expo and React Native project scaffolding, generators, and configuration",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
